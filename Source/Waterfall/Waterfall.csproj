<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="Waterfall.version.props" />
  <PropertyGroup>
    <KSPBT_ModPluginFolder>Plugins</KSPBT_ModPluginFolder>
    <KSPBT_ModRoot>$(MSBuildThisFileDirectory)..\..\GameData\Waterfall</KSPBT_ModRoot>
  </PropertyGroup>
  <ItemGroup>
    <KSPVersionFile Include="Waterfall.version">
      <Destination>$(KSPBT_ModRoot)/Waterfall.version</Destination>
    </KSPVersionFile>
  </ItemGroup>
  <PropertyGroup>
    <TargetFramework>net4.8</TargetFramework>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>9</LangVersion>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="KSPBuildTools" Version="1.1.1" />
    <PackageReference Include="KSPCommunityLib" Version="0.1.1" />
  </ItemGroup>
</Project>